# ============================================================================
# ZAI FLOW 2.0 - Environment Variables Template
# Copy this to .env.production and .env.local, then fill in your values
# ============================================================================

# Supabase Configuration
# Get these from your Supabase project settings
# SUPABASE_URL is constructed from project ID in supabase-init.js
# SUPABASE_ANON_KEY is the publishable/public key from Supabase Settings > API
SUPABASE_ANON_KEY=sb_publishable_xxxxx

# API Configuration (if you have a backend)
# This is used for the /api/login endpoint
API_BASE_URL=https://your-api.example.com

# Application Configuration
APP_NAME=ZAI FLOW 2.0
APP_ENV=production
